# LLM Configuration (支持任意 OpenAI 兼容接口)
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://www.aiping.cn/api/v1
OPENAI_MODEL=DeepSeek-V3.2
EMBEDDING_MODEL=text-embedding-v1

# Vector RAG (Milvus Lite)
VECTOR_RAG_ENABLED=true
VECTOR_TOP_K=5
VECTOR_CACHE_TTL_SECONDS=120

# Application
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO